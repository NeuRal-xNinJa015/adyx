{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {cowboy, "2.12.0"},      %% HTTP/WebSocket server
    {jsx,    "3.1.0"},       %% JSON encoding/decoding
    {uuid,   "2.0.7", {pkg, uuid_erl}}  %% UUID generation
]}.

{relx, [
    {release, {aegis_router, "0.1.0"}, [
        aegis_router,
        sasl
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]},
    {test, [
        {deps, [
            {meck, "0.9.2"}  %% Mocking framework
        ]}
    ]}
]}.

{shell, [
    {apps, [aegis_router]}
]}.
