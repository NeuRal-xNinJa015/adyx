{application, aegis_router,
 [{description, "AegisComms Real-time Messaging Router"},
  {vsn, "0.1.0"},
  {registered, []},
  {mod, {aegis_router_app, []}},
  {applications,
   [kernel,
    stdlib,
    crypto,
    ssl,
    inets
   ]},
  {env, [
    {listen_port, 8443},
    {max_connections, 100000},
    {heartbeat_interval, 30000}
  ]},
  {modules, []},
  {licenses, ["Proprietary"]},
  {links, []}
 ]}.
